SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Shared secret required to authorise the Supabase DB webhook -> /webhook/analyze-profile.
# Set the same value as a custom header (X-Webhook-Secret) on the Supabase webhook.
SUPABASE_WEBHOOK_SECRET=generate_a_long_random_secret
# Comma-separated list of allowed browser origins for CORS (Vercel + local dev).
FRONTEND_ORIGINS=https://your-app.vercel.app,http://localhost:3000
